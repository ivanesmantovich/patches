+quint32 Xkb::clientLayoutForForwarding() const
+{
+    const Qt::KeyboardModifiers shortcutModifiers = Qt::ControlModifier | Qt::AltModifier | Qt::MetaModifier;
+    if (m_modifiers.testAnyFlags(shortcutModifiers)) {
+        return 0;
+    }
+    return m_currentLayout;
+}
+
+void Xkb::forwardClientModifiers()
+{
+    if (!m_seat || !m_seat->keyboard()) {
+        return;
+    }
+    m_seat->notifyKeyboardModifiers(m_modifierState.depressed,
+                                    m_modifierState.latched,
+                                    m_modifierState.locked,
+                                    clientLayoutForForwarding());
+}
